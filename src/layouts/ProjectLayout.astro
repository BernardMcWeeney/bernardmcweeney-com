---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  status: "active" | "development" | "planned" | "archived";
  tech?: string[];
  liveUrl?: string;
  featureImage?: string;
}

const { title, description, status, tech, liveUrl, featureImage } = Astro.props;

const statusLabels = {
  active: "Live",
  development: "In Development",
  planned: "Planned",
  archived: "Archived",
};
---

<Layout title={title} description={description}>
  <article class="project-page">
    <div class="container container--narrow">
      <header class="project-header">
        <a href="/" class="back-link">&larr; All Projects</a>

        <div class="title-row">
          <h1>{title}</h1>
          <span class={`status ${status}`}>{statusLabels[status]}</span>
        </div>

        <p class="project-desc">{description}</p>

        {tech && tech.length > 0 && (
          <div class="tech-list">
            {tech.map((t) => (
              <span class="tech">{t}</span>
            ))}
          </div>
        )}

        {liveUrl && (
          <div class="project-link">
            <a href={liveUrl} class="btn" target="_blank" rel="noopener">
              Visit site &rarr;
            </a>
          </div>
        )}
      </header>

      {featureImage && (
        <img src={featureImage} alt={title} class="feature-image" />
      )}

      <div class="project-content prose">
        <slot />
      </div>

      <footer class="project-footer">
        <a href="/" class="back-link">&larr; All Projects</a>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .project-header {
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .title-row h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .status {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .status.active {
    border-color: #22c55e;
    color: #16a34a;
    background: #f0fdf4;
  }

  .status.development {
    border-color: #f59e0b;
    color: #d97706;
    background: #fffbeb;
  }

  .project-desc {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.5rem;
  }

  .tech {
    font-size: 0.7rem;
    padding: 0.15rem 0.45rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: 3px;
    font-weight: 500;
  }

  .project-link {
    margin-bottom: 0;
  }

  .btn {
    display: inline-block;
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 5px;
    font-weight: 500;
    transition: opacity 0.15s;
  }

  .btn:hover {
    opacity: 0.8;
  }

  .feature-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .project-content {
    max-width: 65ch;
  }

  .project-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 480px) {
    .title-row h1 {
      font-size: 1.5rem;
    }
  }
</style>
