---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.category === "ventures")
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Ventures"
  description="Businesses, brands, and passion projects by Bernard McWeeney."
>
  <div class="container">
    <header class="page-header">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Businesses & Passions
      </div>
      <h1>Ventures</h1>
      <p class="page-intro">
        The businesses I've founded, the brands I'm building, and the passion projects that keep me going.
        These are the things I care about most.
      </p>
    </header>

    <div class="projects-list">
      {projects.map((project) => (
        <ProjectCard
          slug={project.slug}
          title={project.data.title}
          tagline={project.data.tagline}
          description={project.data.description}
          status={project.data.status}
          tech={project.data.tech}
          liveUrl={project.data.liveUrl}
        />
      ))}
    </div>

    <section class="page-cta">
      <p>
        Interested in what I'm building? Always happy to chat about any of these projects.
      </p>
      <a href="mailto:hello@bernardmcweeney.com" class="btn btn-primary">Get in Touch</a>
    </section>
  </div>
</Layout>

<style>
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(14, 165, 233, 0.1);
    border: 1px solid rgba(14, 165, 233, 0.3);
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #0284c7;
    margin-bottom: 1.5rem;
  }

  .dark .hero-badge {
    background: rgba(14, 165, 233, 0.15);
    color: #38bdf8;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: #0ea5e9;
    border-radius: 50%;
  }

  .page-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    line-height: 1.7;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .page-cta {
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, var(--color-sky-light) 0%, rgba(125, 211, 252, 0.3) 100%);
    border-radius: 1.5rem;
    margin-top: 3rem;
  }

  .dark .page-cta {
    background: linear-gradient(135deg, rgba(14, 165, 233, 0.15) 0%, rgba(14, 165, 233, 0.05) 100%);
  }

  .page-cta p {
    margin: 0 0 1.5rem 0;
    color: var(--color-text);
    font-size: 1.05rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 1.5rem;
  }
</style>
