---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.category === "consultancy")
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Consultancy"
  description="Enterprise IT consultancy and services through Waymark - Microsoft 365, security, governance, and cloud infrastructure."
>
  <div class="container">
    <header class="page-header">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Available for Work
      </div>
      <h1>Consultancy</h1>
      <p class="page-intro">
        Enterprise IT consultancy through <a href="/projects/waymark">Waymark</a>.
        Microsoft cloud ecosystems, security, governance, and infrastructure at scale.
      </p>
    </header>

    <div class="projects-list">
      {projects.map((project) => (
        <ProjectCard
          slug={project.slug}
          title={project.data.title}
          tagline={project.data.tagline}
          description={project.data.description}
          status={project.data.status}
          tech={project.data.tech}
          liveUrl={project.data.liveUrl}
        />
      ))}
    </div>

    <section class="page-cta">
      <h2>Need IT Consultancy?</h2>
      <p>
        I specialise in Microsoft cloud environments, security frameworks, and IT governance.
        If your organisation needs clarity rather than jargon, let's talk.
      </p>
      <div class="cta-actions">
        <a href="mailto:hello@bernardmcweeney.com" class="btn btn-primary">Get in Touch</a>
        <a href="https://linkedin.com/in/bernardmcweeney" target="_blank" rel="noopener" class="btn">LinkedIn</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #15803d;
    margin-bottom: 1.5rem;
  }

  .dark .hero-badge {
    background: rgba(34, 197, 94, 0.15);
    color: #4ade80;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }

  .page-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    line-height: 1.7;
  }

  .page-intro a {
    color: var(--color-sky-dark);
    font-weight: 600;
  }

  .dark .page-intro a {
    color: var(--color-sky);
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .page-cta {
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, var(--color-sky-light) 0%, rgba(125, 211, 252, 0.3) 100%);
    border-radius: 1.5rem;
    margin-top: 3rem;
  }

  .dark .page-cta {
    background: linear-gradient(135deg, rgba(14, 165, 233, 0.15) 0%, rgba(14, 165, 233, 0.05) 100%);
  }

  .page-cta h2 {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
  }

  .page-cta p {
    margin: 0 0 1.5rem 0;
    color: var(--color-text);
    font-size: 1.05rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 1.5rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
