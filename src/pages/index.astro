---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { resolveProjectThumbnail } from "../utils/project-thumbnails";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);
const projectCards = await Promise.all(
  projects.map(async (project) => ({
    project,
    resolvedThumbnail: await resolveProjectThumbnail({
      liveUrl: project.data.liveUrl,
      thumbnail: project.data.thumbnail,
    }),
  })),
);
---

<Layout title="Home" description="Projects by Bernard McWeeney.">
  <div class="container">
    <header class="intro">
      <h1>Bernard McWeeney</h1>
      <p>I build websites, tools, and platforms. Based in Meath, Ireland — working across web development, IT consultancy, and a handful of side projects that keep things interesting.</p>
    </header>

    <section class="projects-section">
      <h2 class="section-title">Projects</h2>
      <div class="projects-grid">
        {projectCards.map(({ project, resolvedThumbnail }) => (
          <ProjectCard
            slug={project.slug}
            title={project.data.title}
            description={project.data.description}
            status={project.data.status}
            tech={project.data.tech}
            liveUrl={project.data.liveUrl}
            thumbnail={resolvedThumbnail?.url}
            thumbnailFit={resolvedThumbnail?.fit}
          />
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .intro {
    padding: 2rem 0 3rem;
    max-width: 560px;
  }

  .intro h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.75rem;
  }

  .intro p {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-muted);
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 540px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 860px) {
    .projects-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
