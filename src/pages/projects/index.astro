---
import Layout from "../../layouts/Layout.astro";

const groups = [
  {
    title: "Ventures",
    description: "Businesses, brands, and passion projects.",
    href: "/ventures",
  },
  {
    title: "Consultancy",
    description: "Enterprise IT, Microsoft cloud, security, and governance.",
    href: "/consultancy",
  },
  {
    title: "Websites",
    description: "Website design for communities, local projects, and experiments.",
    href: "/websites",
  },
  {
    title: "Hardware",
    description: "Networking, home automation, and physical infrastructure.",
    href: "/hardware",
  },
  {
    title: "Ideas",
    description: "Concepts and projects in the planning stages.",
    href: "/ideas",
  },
];
---

<Layout
  title="Projects"
  description="A collection of things I've built and am working on."
>
  <div class="container">
    <header class="page-header">
      <h1>Projects</h1>
      <p class="page-intro">
        My work is split across a few areas. Pick one to explore.
      </p>
    </header>

    <div class="groups-grid">
      {groups.map((group) => (
        <a href={group.href} class="group-card">
          <h2>{group.title}</h2>
          <p>{group.description}</p>
          <span class="group-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .groups-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .group-card {
    display: block;
    padding: 2rem;
    background: var(--color-cloud);
    border-radius: 1rem;
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.2s ease;
    position: relative;
  }

  .group-card:hover {
    border-color: var(--color-sky);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(14, 165, 233, 0.1);
  }

  .group-card h2 {
    font-size: 1.25rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
  }

  .group-card:hover h2 {
    color: var(--color-sky-dark);
  }

  .dark .group-card:hover h2 {
    color: var(--color-sky);
  }

  .group-card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .group-arrow {
    position: absolute;
    top: 2rem;
    right: 2rem;
    font-size: 1.25rem;
    color: var(--color-text-muted);
    transition: transform 0.2s ease;
  }

  .group-card:hover .group-arrow {
    transform: translateX(4px);
    color: var(--color-sky-deep);
  }
</style>
