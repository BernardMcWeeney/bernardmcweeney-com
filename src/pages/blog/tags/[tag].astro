---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../../utils/reading-time";

const isDev = import.meta.env.DEV;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tags = new Set<string>();
  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => tags.add(tag));
  });

  return [...tags].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;

const posts = (await getCollection("blog"))
  .filter((p) => (isDev || !p.data.draft) && p.data.tags?.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={`Posts tagged "${tag}"`} description={`Blog posts tagged with ${tag}.`}>
  <div class="container container--narrow">
    <header class="page-header">
      <a href="/blog/tags" class="back-link">&larr; All Tags</a>
      <h1>#{tag}</h1>
      <p class="post-count">{posts.length} post{posts.length !== 1 ? "s" : ""}</p>
    </header>

    <div class="posts">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="post">
          <div class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("en-IE", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </time>
            <span class="reading-time">{getReadingTime(post.body ?? "")}</span>
          </div>
          <div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .post-count {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post {
    display: flex;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .post:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post:hover {
    opacity: 0.7;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 5.5rem;
    padding-top: 0.15rem;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .reading-time {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .post h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .post p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .post {
      flex-direction: column;
      gap: 0.25rem;
    }

    .post-meta {
      flex-direction: row;
      gap: 0.75rem;
    }
  }
</style>
