---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../utils/reading-time";

const isDev = import.meta.env.DEV;

const posts = (await getCollection("blog"))
  .filter((p) => isDev || !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog" description="Thoughts from Bernard McWeeney.">
  <div class="container container--narrow">
    <header class="page-header">
      <h1>Blog</h1>
    </header>

    <div class="posts">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post">
          <div class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("en-IE", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </time>
            <span class="reading-time">{getReadingTime(post.body ?? "")}</span>
          </div>
          <div>
            <h2>
              {post.data.title}
              {post.data.draft && <span class="draft-badge">Draft</span>}
            </h2>
            <p>{post.data.description}</p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="empty">No posts yet.</p>
    )}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post {
    display: flex;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .post:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post:hover {
    opacity: 0.7;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 5.5rem;
    padding-top: 0.15rem;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .reading-time {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .post h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .draft-badge {
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    border-radius: 9999px;
    background: #fef3c7;
    color: #d97706;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    gap: 0.3rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: 3px;
    font-weight: 500;
  }

  .empty {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 480px) {
    .post {
      flex-direction: column;
      gap: 0.25rem;
    }

    .post-meta {
      flex-direction: row;
      gap: 0.75rem;
    }
  }
</style>
