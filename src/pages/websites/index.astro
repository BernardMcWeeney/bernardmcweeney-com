---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.category === "websites")
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Websites"
  description="Website design and development projects - community sites, local interest, and web experiments."
>
  <div class="container">
    <header class="page-header">
      <h1>Websites</h1>
      <p class="page-intro">
        Website design and development for communities, local projects, and personal experiments.
        Simple, fast sites built to last.
      </p>
    </header>

    <div class="projects-list">
      {projects.map((project) => (
        <ProjectCard
          slug={project.slug}
          title={project.data.title}
          tagline={project.data.tagline}
          description={project.data.description}
          status={project.data.status}
          tech={project.data.tech}
          liveUrl={project.data.liveUrl}
        />
      ))}
    </div>

    <section class="page-cta">
      <p>
        Need a website? I build simple, fast sites for businesses, communities, and causes that matter.
      </p>
      <a href="mailto:hello@bernardmcweeney.com" class="btn btn-primary">Get in Touch</a>
    </section>
  </div>
</Layout>

<style>
  .page-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    line-height: 1.7;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .page-cta {
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, var(--color-sky-light) 0%, rgba(125, 211, 252, 0.3) 100%);
    border-radius: 1.5rem;
    margin-top: 3rem;
  }

  .dark .page-cta {
    background: linear-gradient(135deg, rgba(14, 165, 233, 0.15) 0%, rgba(14, 165, 233, 0.05) 100%);
  }

  .page-cta p {
    margin: 0 0 1.5rem 0;
    color: var(--color-text);
    font-size: 1.05rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 1.5rem;
  }
</style>
