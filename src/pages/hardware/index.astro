---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.category === "hardware")
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Hardware & Infrastructure"
  description="Hardware projects, networking, home automation, and physical infrastructure."
>
  <div class="container">
    <header class="page-header">
      <h1>Hardware & Infrastructure</h1>
      <p class="page-intro">
        Networking, home automation, and physical infrastructure.
        Real-world problems solved with real-world hardware.
      </p>
    </header>

    <div class="projects-list">
      {projects.map((project) => (
        <ProjectCard
          slug={project.slug}
          title={project.data.title}
          tagline={project.data.tagline}
          description={project.data.description}
          status={project.data.status}
          tech={project.data.tech}
          liveUrl={project.data.liveUrl}
        />
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-intro {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    line-height: 1.7;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
